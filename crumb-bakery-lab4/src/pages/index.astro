---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";

import fs from "fs";
import path from "path";
import matter from "gray-matter";

// Load Hero content
const heroFile = fs.readFileSync(path.resolve("./src/content/hero.md"), "utf-8");
const { data: heroData } = matter(heroFile);
---
<Layout>
  <Hero {...heroData} />
  
</Layout>