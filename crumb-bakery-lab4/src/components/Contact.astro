---
const { heading, inputPlaceholder, buttonText, instagramLink, logoSrc } = Astro.props;
---

<section id="contact" class="flex flex-col items-center justify-center min-h-screen px-6 py-12 bg-[#ff90b5] text-center">
  <h2 class="text-white font-bold mb-12 text-[8vw] md:text-[3.5vw]">
    {heading}
  </h2>

  <div class="w-8/12 max-w-md flex flex-col gap-4 bg-white p-6 rounded-2xl shadow-lg">
    <input 
      type="email" 
      placeholder={inputPlaceholder} 
      class="w-full p-4 rounded-lg bg-gray-100 text-gray-800 font-medium focus:outline-none focus:ring-2 focus:ring-gray-300"
    />
    <button 
      class="w-full bg-[#ff90b5] text-white font-semibold py-3 rounded-lg hover:bg-[#c23248] transition-transform duration-200 hover:-translate-y-0.5"
    >
      {buttonText}
    </button>
  </div>

  <a href={instagramLink} class="mt-8">
    <img src={logoSrc} alt="Logo" class="w-28 h-auto mx-auto transition-transform duration-200 hover:-translate-y-1" />
  </a>
</section>