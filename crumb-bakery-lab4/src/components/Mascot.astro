---
const { message, mascotImg } = Astro.props;
---


<div id="mascot" class="group fixed bottom-0 left-0 w-[400px] md:w-[800px] z-[9999] cursor-pointer opacity-100">
<div class="mascot-message absolute left-[50%] md:left-[40%] bottom-[90%] bg-white/60 text-black px-4 py-2 rounded-lg font-poppins font-semibold text-sm md:text-base
           opacity-0 group-hover:opacity-100 pointer-events-none transform -rotate-[16deg] -translate-x-1/2 -translate-y-[5px] transition-opacity duration-500"   
           set:html={message}>
  
  </div>

  <a href="#contact">
    <img src={mascotImg} alt="Crumb Bakery Mascot" class="w-[30%] transition-transform duration-200 pointer-events-auto" />
  </a>
</div>